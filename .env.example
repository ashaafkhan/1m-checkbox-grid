# Server
PORT=8080

# Redis
# Example: redis://localhost:6379
REDIS_URL=
REDIS_BITMASK_KEY=checkboxes:bitmask

# Clerk
# Example: pk_test_... (frontend) / sk_test_... (server)
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Rate limiting
RATE_LIMIT_HTTP_WINDOW_MS=10000
RATE_LIMIT_HTTP=30
RATE_LIMIT_TOGGLE_WINDOW_MS=2000
RATE_LIMIT_TOGGLE=40
RATE_LIMIT_RESET_WINDOW_MS=60000
RATE_LIMIT_RESET=2
